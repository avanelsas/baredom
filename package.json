  },
  "version": "2.7.0",
  "sideEffects": [
    "./dist/*.js"
  ],
  "description": "Native Web Components with centralised theming — stateless, framework-free, zero runtime. Built with ClojureScript, compiled to tree-shakeable ESM.",
  "scripts": {
    "clean": "rm -rf dist .shadow-cljs",
    "build": "npm run clean && npx shadow-cljs release lib && bb scripts/generate_types.bb && ./scripts/generate-integrity.sh",
    "build:demo": "npx shadow-cljs release demo",
    "pack:local": "npm pack",
    "test": "npx shadow-cljs compile test-karma && npx karma start karma.conf.cjs --single-run",
    "test:types": "npx tsc -p test/types/tsconfig.json",
    "build:react": "bb scripts/generate_react.bb && cd adapters/react && npx tsc"
  }
}
