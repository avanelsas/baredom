{:source-paths ["src"]

 ;; Local dev only. push-state fallback serves index.html for any path that does
 ;; not resolve to a file, so a refresh or deep-link of a client route (e.g.
 ;; /tasks/1) loads the app instead of 404ing. For the e2e run and any realistic
 ;; backend, `bb serve` (server/serve.clj) provides the same fallback alongside
 ;; the JSON API on a single origin.
 :dev-http
 {8000 {:root "public" :push-state/index "index.html"}}

 :builds
 {:app
  {:target     :browser
   :output-dir "public/js"
   :asset-path "/js"
   :modules    {:main {:init-fn demo-app.core/init!}}
   :devtools   {:after-load demo-app.core/reload!}}}}
