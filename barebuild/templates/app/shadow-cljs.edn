{:source-paths ["src"]

 ;; push-state fallback: serve index.html for any path that does not resolve to a
 ;; file, so a refresh or deep-link of a client route (e.g. /users) loads the app
 ;; instead of 404ing. A production server needs the same SPA fallback.
 :dev-http
 {8000 {:root "public" :push-state/index "index.html"}}

 :builds
 {:app
  {:target     :browser
   :output-dir "public/js"
   :asset-path "/js"
   :modules    {:main {:init-fn APP_NAME.core/init!}}
   :devtools   {:after-load APP_NAME.core/reload!}}}}
